{
  "manifest_version": 3,
  "name": "Rename Tabs & Change Tab Icons: TabMaster",
  "version": "1.0.0",
  "description": "Rename browser tabs & change tab icons automatically with URL rules. Customize tab titles, use emojis, or upload custom images.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "tabs",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Open Tab Customizer Settings"
  },
  "options_page": "options/options.html",
  "background": {
    "service_worker": "background.js"
  }
}
